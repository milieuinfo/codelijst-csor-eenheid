@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix xhv:           <http://www.w3.org/1999/xhtml/vocab#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:          <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix omg_dataset:   <https://data.omgeving.vlaanderen.be/id/dataset/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix omg_ont:       <https://data.omgeving.vlaanderen.be/id/ontology/> .
@prefix omg_ag_cl:     <https://data.omgeving.vlaanderen.be/id/person/codelijst/> .
@prefix omg_voc:       <https://data.omgeving.vlaanderen.be/ns/> .
@prefix vl_org:        <http://data.vlaanderen.be/id/organisatie/> .
@prefix xkos:          <http://rdf-vocabulary.ddialliance.org/xkos#> .
@prefix omg_ps:        <https://data.omgeving.vlaanderen.be/id/propertyshape/> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ons:           <https://data.omgeving.vlaanderen.be/id/nodeshape/> .
@prefix schema:        <http://schema.org/> .
@prefix foaf:          <http://xmlns.com/foaf/0.1/> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .

omg_ont:csor-eenheid-ap-constraints
    a               owl:Ontology ;
    rdfs:comment
                    "Specifieert hoe de data in de codelijst van CSOR eenheden te encoderen in RDF (i.e. RDF termen, kardinaliteiten,...)."@en ;
    rdfs:label      "CSOR Eenheid AP Constraints"@en ;
    dct:abstract    "Het CSOR eenheid applicatieprofiel specifieert de RDF termen (klassen en properties) en bijhorende constraints die gebruikt worden voor het beschrijven van eenheden in het Chemische Stoffen en Omgevingsparameters-Register (CSOR). Het maakt hierbij zoveel mogelijk gebruik van bestaande termen (klassen en properties) uit bestaande vocabularia zoals skos, csor en qudt."@en ;
    dct:alternative "CSOR Eenheid AP Shapes"@en ;
    dct:creator     omg_ag_cl:creator ;
    dct:description "Dit is de SHACL encodering van het applicatieprofiel van een CSOR eenheid."@en ;
    dct:issued      "2026-05-20"^^xsd:date ;
    dct:title       "CSOR Eenheid AP Constraints"@en ;
    xkos:belongsTo  omg_dataset:codelijst-csor-eenheid ;
    xhv:last        omg_voc:csor-eenheid-ap-constraints ;
    owl:sameAs      omg_voc:csor-eenheid-ap-constraints ;
    owl:versionInfo "Versie 1.0.0  mei 2026"@en .


omg_voc:csor-eenheid-ap-constraints
    a          owl:Ontology ;
    rdfs:label "CSOR Eenheid AP Constraints"@en ;
    owl:sameAs omg_ont:csor-eenheid-ap-constraints .

omg_ag_cl:creator
    rdfs:label "Ontwikkelaar codelijst"@en ;
    schema:affiliation vl_org:OVO003749 ;
    a foaf:Person;
    foaf:firstName "Geert";
    foaf:lastName "Van Haute";
    foaf:mbox <mailto:geert.vanhaute@vlaanderen.be>.

# Node Shapes
ons:schema
    a                sh:NodeShape ;
    rdfs:label       "conceptschema van CSOR eenheden"@en ;
    sh:name          "conceptschema van CSOR eenheden"@en ;
    sh:description   "Het schema waarbinnen de CSOR eenheden gedefinieerd zijn"@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:property      omg_ps:conceptscheme_prefLabel, omg_ps:schema_hasTopConcept,
                     omg_ps:definition, omg_ps:rdf_type;

    sh:targetClass   skos:ConceptScheme .



ons:eenheid
    a                sh:NodeShape ;
    rdfs:label       "eenheid"@en ;
    sh:name          "eenheid"@en ;
    sh:description   "Een standaard waarmee een kwantiteit wordt uitgedrukt, gebruikt voor het kwantificeren van observaties in het CSOR-register."@en ;
    rdfs:comment     ""@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:property      omg_ps:notation, omg_ps:inScheme,
                     omg_ps:definition,
                     omg_ps:prefLabel,
                      omg_ps:topConceptOf, omg_ps:altLabel,
                     omg_ps:rdf_type, omg_ps:note ;

    sh:targetClass   skos:Concept .



# Property Shapes

omg_ps:rdf_type
    a                sh:PropertyShape ;
    rdfs:label       "rdf type"@en ;
    sh:name          "rdf type"@en ;
    sh:description   "Aanduiding dat een bron een instantie van een bepaalde klasse is."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;

    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          rdf:type .


omg_ps:topConceptOf
    a                sh:PropertyShape ;
    rdfs:label       "topconcept van"@en ;
    sh:name          "topconcept van"@en ;
    sh:description   "De relatie tussen een concept en het schema, waarvan het een topconcept is."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:class         skos:ConceptScheme ;
    sh:maxCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:topConceptOf .


omg_ps:altLabel
    a                sh:PropertyShape ;
    rdfs:label       "alternatief label"@en ;
    sh:name          "alternatief label"@en ;
    sh:description   "Een alternatief lexicaal label voor een bepaalde bron."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" "en" ) ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:altLabel .

omg_ps:notation
    a                sh:PropertyShape ;
    rdfs:label       "notatie"@en ;
    sh:name          "notatie"@en ;
    sh:description   "Een notatie, ook wel symbool genoemd, is een reeks tekens zoals \"mg/L\" of \"µg/kg\" die wordt gebruikt om een eenheid op unieke wijze te identificeren binnen de context van dit schema."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      xsd:string ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:notation .

omg_ps:schema_hasTopConcept
    a                sh:PropertyShape ;
    rdfs:label       "heeft topconcept"@en ;
    sh:name          "heeft topconcept"@en ;
    sh:description   "Verbindt een conceptschema met een concept dat bovenaan in een 'broader/narrower' hierarchie staat en voorziet aldus een ingang tot die hierarchie."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:class         skos:Concept ;
    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:hasTopConcept .


omg_ps:definition
    a                sh:PropertyShape ;
    rdfs:label       "definitie"@en ;
    sh:name          "definitie"@en ;
    sh:description   "Een uitspraak over de betekenis van het concept of het schema."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" "en" ) ;
    sh:maxCount      2 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:definition .

omg_ps:note
    a                sh:PropertyShape ;
    rdfs:label       "note"@en ;
    sh:name          "note"@en ;
    sh:description   "Een uitspraak over de betekenis van het concept of het schema."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" "en" ) ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:note .

omg_ps:prefLabel
    a                sh:PropertyShape ;
    rdfs:label       "voorkeurslabel"@en ;
    sh:name          "voorkeurslabel"@en ;
    sh:description   "Het voorkeurslabel in de Nederlandse taal. Slechts 1 voorkeurslabel is toegelaten."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" ) ;
    sh:maxCount      1 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:prefLabel .


omg_ps:conceptscheme_prefLabel
    a                sh:PropertyShape ;
    rdfs:label       "voorkeurslabel"@en ;
    sh:name          "voorkeurslabel"@en ;
    sh:description   "Het voorkeurslabel."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "en" "nl" ) ;
    sh:uniqueLang true ;
    sh:maxCount      2 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:prefLabel .

omg_ps:inScheme
    a                sh:PropertyShape ;
    rdfs:label       "is in schema"@en ;
    sh:name          "is in schema"@en ;
    sh:description   "Drukt de relatie uit tussen een 'resource' en het schema dat het bevat."@en ;
    rdfs:isDefinedBy omg_ont:csor-eenheid-ap-constraints, omg_voc:csor-eenheid-ap-constraints ;
    sh:class         skos:ConceptScheme ;
    sh:maxCount      1 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:inScheme .
